                "variables": ""
              }
            }
          },
          "response": []
        },
        {
          "name": "Criar Pedido sem autenticação (deve retornar erro)",
          "request": {
            "method": "POST",
            "url": "http://localhost:8082/graphql",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CriarPedido($input: CriarPedidoInput!) {\n  criarPedido(input: $input) {\n    id\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"restauranteId\": \"{{restauranteId}}\",\n    \"itens\": [\n      {\n        \"produtoId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n        \"nome\": \"X-Burger\",\n        \"quantidade\": 1,\n        \"preco\": \"25.90\"\n      }\n    ]\n  }\n}"
              }
            }
          },
          "response": []
