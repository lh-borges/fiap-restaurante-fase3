"""
Schema GraphQL — módulo de pagamento
"""

type Pagamento {
    id: ID!
    pedidoId: ID!
    valor: Float!
    status: String!
    tentativas: Int!
    motivoFalha: String
    createdAt: String!
    updatedAt: String!
}

type Query {
    "Consulta o pagamento associado a um pedido. Requer autenticação."
    pagamentoPorPedido(pedidoId: ID!): Pagamento

    "Lista pagamentos com status PENDENTE. Requer autenticação."
    pagamentosPendentes: [Pagamento!]!
}
